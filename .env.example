STT_URL=http://localhost:8000
PORT=8787
VITE_DEBUG=0

# STT service config (used by docker-compose or when running stt/ directly)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
STT_TIMESTAMPS=segments
STT_VERBATIM=true
STT_FALLBACK_NO_VAD=true
STT_FALLBACK_LONG_AUDIO_SECONDS=6
STT_FALLBACK_MIN_WORDS_LONG_AUDIO=3
STT_FALLBACK_ZERO_FILLERS_SECONDS=10
STT_FALLBACK_MIN_SPEECH_RATIO=0.25
